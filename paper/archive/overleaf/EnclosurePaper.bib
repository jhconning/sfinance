@article{huntington2021,
  ids = {huntington2021a},
  title = {Does Insecure Land Tenure Deter Investment? {{Evidence}} from a Randomized Controlled Trial},
  shorttitle = {Does Insecure Land Tenure Deter Investment?},
  author = {Huntington, Heather and Shenoy, Ajay},
  date = {2021-05-01},
  journaltitle = {Journal of Development Economics},
  shortjournal = {Journal of Development Economics},
  volume = {150},
  pages = {102632},
  issn = {0304-3878},
  url = {https://www.sciencedirect.com/science/article/pii/S0304387821000110},
  urldate = {2021-02-16},
  abstract = {There is broad agreement among the most prominent observational studies that tenure insecurity deters investment. We present new experimental evidence testing this proposition: a land certification program randomized across villages in Zambia. Our results contradict the consensus. Though the intervention improved perceptions of tenure security, it had no impact on investment in the following season. The impact is still zero even after a cross-randomized agroforestry extension relaxes financial and technical constraints to agroforestry investment. Though relaxing these constraints has a direct effect, it is not enhanced by granting land tenure, implying tenure insecurity had not been a barrier to investment.},
  langid = {english},
  keywords = {O13,P48,Zambia},
  file = {H\:\\My Drive\\B\\zotero\\storage\\46JUSVGD\\Huntington and Shenoy - 2021 - Does insecure land tenure deter investment Eviden.pdf;H\:\\My Drive\\B\\zotero\\storage\\NUEGWH5J\\Huntington and Shenoy - 2021 - Does insecure land tenure deter investment Eviden.pdf;H\:\\My Drive\\B\\zotero\\storage\\PJ88ZJTP\\Huntington_Shenoy_2021_Does insecure land tenure deter investment.pdf;H\:\\My Drive\\B\\zotero\\storage\\YMH8UXSN\\Huntington_Shenoy_2021_Does insecure land tenure deter investment.pdf;H\:\\My Drive\\B\\zotero\\storage\\4GW2D3ET\\S0304387821000110.html;H\:\\My Drive\\B\\zotero\\storage\\FZ7HML4K\\S0304387821000110.html;H\:\\My Drive\\B\\zotero\\storage\\NIAKAZDF\\S0304387821000110.html;H\:\\My Drive\\B\\zotero\\storage\\ZQZYICSD\\S0304387821000110.html}
