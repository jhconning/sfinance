@article{lueck1995,
  title = {The {{Rule}} of {{First Possession}} and the {{Design}} of the {{Law}}},
  author = {Lueck, Dean},
  date = {1995-10-01},
  journaltitle = {The Journal of Law and Economics},
  shortjournal = {The Journal of Law and Economics},
  volume = {38},
  number = {2},
  pages = {393--436},
  publisher = {{The University of Chicago Press}},
  issn = {0022-2186},
  url = {https://www.journals.uchicago.edu/doi/abs/10.1086/467337},
  urldate = {2020-11-20},
  abstract = {Economists have shown that first possession might cause rent dissipation from racing or overexploitation. In this study, I develop models that show how dissipation can be avoided and use the derived implications to explain the observed pattern of first possession rules in a variety of legal fields. The analysis hinges on the recognition that possession may extend to either the entire stock of a resource or simply a onetime flow from that stock. Not only do the paths of rent dissipation depend on this distinction, but so do the predicted responses of the law. When first possession has the potential for a race, the law tends to mitigate dissipation by assigning possession when differences between claimants are greatest. Alternatively, when first possession leads to overexploitation through a rule of capture, the law tends to limit access and restrict the transfer of access rights in order to limit open access dissipation.},
  file = {H\:\\My Drive\\B\\zotero\\storage\\9XXIS4KW\\467337.html;H\:\\My Drive\\B\\zotero\\storage\\GA3MV34C\\467337.html;H\:\\My Drive\\B\\zotero\\storage\\NV78P99I\\467337.html;H\:\\My Drive\\B\\zotero\\storage\\UAZ7E7JN\\467337.html}
}

