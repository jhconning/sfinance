@article{jayne2016,
  title = {Africa's Changing Farm Size Distribution Patterns: The Rise of Medium-Scale Farms},
  shorttitle = {Africa's Changing Farm Size Distribution Patterns},
  author = {Jayne, T. S. and Chamberlin, Jordan and Traub, Lulama and Sitko, Nicholas and Muyanga, Milu and Yeboah, Felix K. and Anseeuw, Ward and Chapoto, Antony and Wineman, Ayala and Nkonde, Chewe and Kachule, Richard},
  date = {2016},
  journaltitle = {Agricultural Economics},
  volume = {47},
  number = {S1},
  pages = {197--214},
  issn = {1574-0862},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/agec.12308},
  urldate = {2021-06-04},
  abstract = {This study assesses changes over the past decade in the farm size distributions of Ghana, Kenya, Tanzania, and Zambia, drawing on two or more waves of nationally representative population-based and/or area-based surveys. Analysis indicates that much of Sub-Saharan Africa is experiencing major changes in farm land ownership patterns. Among all farms below 100 hectares in size, the share of land on small-scale holdings under five hectares has declined except in Kenya. Medium-scale farms (defined here as farm holdings between 5 and 100 hectares) account for a rising share of total farmland, especially in the 10–100 hectare range where the number of these farms is growing especially rapidly. Medium-scale farms control roughly 20\% of total farmland in Kenya, 32\% in Ghana, 39\% in Tanzania, and over 50\% in Zambia. The numbers of such farms are also growing very rapidly, except in Kenya. We also conducted detailed life history surveys of medium-scale farmers in each of these four countries and found that the rapid rise of medium-scale holdings in most cases reflects increased interest in land by urban-based professionals or influential rural people. About half of these farmers obtained their land later in life, financed by nonfarm income. The rise of medium-scale farms is affecting the region in diverse ways that are difficult to generalize. Many such farms are a source of dynamism, technical change, and commercialization of African agriculture. However, medium-scale land acquisitions may exacerbate land scarcity in rural areas and constrain the rate of growth in the number of small-scale farm holdings. Medium-scale farmers tend to dominate farm lobby groups and influence agricultural policies and public expenditures to agriculture in their favor. Nationally representative Demographic and Health Survey (DHS) data from six countries (Ghana, Kenya, Malawi, Rwanda, Tanzania, and Zambia) show that urban households own 5–35\% of total agricultural land and that this share is rising in all countries where DHS surveys were repeated. This suggests a new and hitherto unrecognized channel by which medium-scale farmers may be altering the strength and location of agricultural growth and employment multipliers between rural and urban areas. Given current trends, medium-scale farms are likely to soon become the dominant scale of farming in many African countries.},
  langid = {english},
  keywords = {Malawi},
  file = {H\:\\My Drive\\B\\zotero\\storage\\5YGLM9EU\\Jayne et al_2016_Africa's changing farm size distribution patterns.pdf;H\:\\My Drive\\B\\zotero\\storage\\VPHWAV2M\\Jayne et al_2016_Africa's changing farm size distribution patterns.pdf;H\:\\My Drive\\B\\zotero\\storage\\C76PG96N\\agec.html;H\:\\My Drive\\B\\zotero\\storage\\PXRCPU59\\agec.html}
}

@article{jedwab2017,
  title = {Demography, Urbanization and Development: {{Rural}} Push, Urban Pull And…urban Push?},
  shorttitle = {Demography, Urbanization and Development},
  author = {Jedwab, Remi and Christiaensen, Luc and Gindelsky, Marina},
  date = {2017-03-01},
  journaltitle = {Journal of Urban Economics},
  shortjournal = {Journal of Urban Economics},
  series = {Urbanization in {{Developing Countries}}: {{Past}} and {{Present}}},
  volume = {98},
  pages = {6--16},
  issn = {0094-1190},
  url = {https://www.sciencedirect.com/science/article/pii/S0094119015000601},
  urldate = {2022-10-10},
  abstract = {Developing countries have urbanized rapidly since 1950. To explain urbanization, standard models emphasize rural–urban migration, focusing on rural push factors (agricultural modernization and rural poverty) and urban pull factors (industrialization and urban-biased policies). Using new historical data on urban birth and death rates for 7 countries from Industrial Europe (1800–1910) and 35 developing countries (1960–2010), we argue that a non-negligible part of developing countries’ rapid urban growth and urbanization may also be linked to demographic factors, i.e. rapid internal urban population growth, or an urban push. High urban natural increase in today’s developing countries follows from lower urban mortality, relative to Industrial Europe, where higher urban deaths offset urban births. This compounds the effects of migration and displays strong associations with urban congestion, providing additional insight into the phenomenon of urbanization without growth.},
  langid = {english},
  keywords = {Congestion,Killer cities,Migration,Mushroom cities,Population growth,Slums,Urban mortality,Urban push,Urbanization},
  file = {H\:\\My Drive\\B\\zotero\\storage\\NCC3XED7\\Jedwab et al_2017_Demography, urbanization and development.pdf;H\:\\My Drive\\B\\zotero\\storage\\QS8AMWIP\\S0094119015000601.html}
}

