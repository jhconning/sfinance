@article{libecap1989,
  title = {Distributional {{Issues}} in {{Contracting}} for {{Property Rights}}},
  author = {Libecap, Gary D.},
  date = {1989},
  journaltitle = {Journal of Institutional and Theoretical Economics (JITE) / Zeitschrift für die gesamte Staatswissenschaft},
  volume = {145},
  number = {1},
  eprint = {40751163},
  eprinttype = {jstor},
  pages = {6--24},
  publisher = {{Mohr Siebeck GmbH \& Co. KG}},
  issn = {0932-4569},
  url = {http://www.jstor.org/stable/40751163},
  urldate = {2021-06-10},
  abstract = {The paper examines four political contracting efforts to change property rights in response to common pool problems with very different results. The cases include private mineral rights on federal land; private rights to federal timber and agricultural land; fishery rights; and property rights to crude oil production in the U.S. There is a progression across the cases in the complexity of contracting and the degree to which clearly-defined exclusive rights were assigned. The principal contracting issue was the distribution of the aggregate benefits of property rights change. Compromises to readjust shares in efforts to reach agreement changed the nature of the institutions that ultimately were adopted and the nature of the aggregate benefits that were received. The analysis suggests that institutional change to promote rational resource use and economic growth cannot be taken for granted and where it occurs, will bring only modest gains at any time. To understand variation in property rights, attention must be directed to distributional conflicts and the side payments adopted to promote agreement. In diesem Artikel werden vier verschiedene Vertragsstrategien untersucht, die alle mit unterschiedlichen Ergebnissen darauf abzielen, eine Änderung der Verfügungsrechte als Reaktion auf das Common Pool Problem herbeizuführen. Die behandelten Fälle beziehen sich auf die privaten Abbaurechte mineralischer Rohstoffe auf staatlichem Gelände, auf private Nutzungsrechte an staatlichem Forst- und Ackergelände, Fischereirechte und Verfügungsrechte für eine Ölförderung in den USA. Es stellt sich eine Zunahme in der Komplexität der Vertragsgestaltung bei den einzelnen Fällen ein. Gleiches trifft auf das Ausmaß zu, in dem genau spezifizierte, ausschlieBliche Rechte zugeordnet wurden. Den Hauptaspekt der Vertragsgestaltung bildete die Verteilung der aggregierten Vorteile, die aus der Änderung der Verfügungsrechte erwuchsen. Eingegangene Kompromisse bei der Anpassung der Anteile an den Vorteilen, die dazu dienten, überhaupt eine Einigung herbeizuführen, änderten ihrerseits wiederum die Natur der Institution, die letztendlich eingeführt wurde, ebenso wie die Natur der aggregierten Vorteile. Die Untersuchung deutet darauf hin, daß eine institutionelle Änderung zur Förderung einer rationalen Rohstoffnutzung und des wirtschaftlichen Wachstums nicht als selbstverständlich hingenommen werden können. Wo sie eintreten, bringen sie immer nur bescheidene Gewinne. Um Änderungen von Verfügungsrechten zu verstehen, muß sich die Aufmerksamkeit auf die Verteilungskonflikte richten und auf die Kompensationszahlungen, die zur Förderung von Übereinkünften geleistet werden.},
  file = {H\:\\My Drive\\B\\zotero\\storage\\2EWZSPKX\\Libecap_1989_Distributional Issues in Contracting for Property Rights.pdf;H\:\\My Drive\\B\\zotero\\storage\\EFALQY92\\Libecap_1989_Distributional Issues in Contracting for Property Rights.pdf}
}

