  pages = {119--138},
  issn = {1435-8131},
  url = {https://doi.org/10.1007/s10101-021-00254-x},
  urldate = {2023-03-24},
  abstract = {Hunter-gatherer societies are characterized by decentralized decision making and shared access to resources. Goods are distributed via reciprocal exchange, sharing, and gift-giving, in the end resulting in relatively equal distribution. Work effort, however, is not distributed equally; the best hunters exert a disproportionate share of productive effort. We argue that these features of the hunter-gatherer economy are interrelated, and are consistent with the view that customary gift-giving and sharing arrangements manage usage of open-access resources. In particular, sharing rules can induce optimal hunting effort, while gift-giving can serve to elicit information about hunter productivity.},
  langid = {english},
  keywords = {Common property,D23,D30,D82,Gift-giving,H23,Hunter-gatherers,Resource management,Sharing},
  file = {H:\My Drive\B\zotero\storage\LE6I2EHF\Baker_Swope_2021_Sharing, gift-giving, and optimal resource use in hunter-gatherer society.pdf}
