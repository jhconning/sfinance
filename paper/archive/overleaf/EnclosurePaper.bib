  author = {Deininger, Klaus and Savastano, Sara and Xia, Fang},
  date = {2017-02-01},
  journaltitle = {Food Policy},
  shortjournal = {Food Policy},
  series = {Agriculture in {{Africa}} – {{Telling Myths}} from {{Facts}}},
  volume = {67},
  pages = {78--92},
  issn = {0306-9192},
  url = {http://www.sciencedirect.com/science/article/pii/S0306919216303797},
  urldate = {2017-12-11},
  abstract = {While scholars long recognized the importance of land markets as a key driver of rural non-farm development and transformation in rural areas, evidence on the extent of their operation and the nature of participants remains limited. We use household data from 6 countries to show that there is great potential for such markets to increase productivity and equalize factor ratios. While rental markets transfer land to land-poor and labor-rich producers, their operation and thus impact may be constrained by policy restrictions. Their functioning may also be constrained by ill-defined or insecure rights that may arise from failure to fully compensate existing rights in cases of expropriation, a failure to implement more broadly land policies or to do so in a gender sensitive manner. Methodological and substantive conclusions are derived.},
  issue = {Supplement C},
  keywords = {Africa Flagship},
  file = {H\:\\My Drive\\B\\zotero\\storage\\BKFTKV9L\\Deininger et al_2017_Smallholders’ land access in Sub-Saharan Africa.pdf;H\:\\My Drive\\B\\zotero\\storage\\DU7CWRKV\\Deininger et al_2017_Smallholders’ land access in Sub-Saharan Africa.pdf;H\:\\My Drive\\B\\zotero\\storage\\82PSVACN\\S0306919216303797.html;H\:\\My Drive\\B\\zotero\\storage\\VCUUK2FD\\S0306919216303797.html}
