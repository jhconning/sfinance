@article{goldstein2018,
  title = {Formalization without Certification? {{Experimental}} Evidence on Property Rights and Investment},
  shorttitle = {Formalization without Certification?},
  author = {Goldstein, Markus and Houngbedji, Kenneth and Kondylis, Florence and O'Sullivan, Michael and Selod, Harris},
  date = {2018-05-01},
  journaltitle = {Journal of Development Economics},
  shortjournal = {Journal of Development Economics},
  volume = {132},
  pages = {57--74},
  issn = {0304-3878},
  url = {https://www.sciencedirect.com/science/article/pii/S030438781730127X},
  urldate = {2021-08-09},
  abstract = {We present evidence from the first large-scale randomized-controlled trial of a land formalization program. We examine the link between land demarcation and investment in rural Benin in light of a model of agricultural production under insecure tenure. The demarcation process involved communities in the mapping and attribution of land rights; cornerstones marked parcel boundaries and offered lasting landmarks. The tenure security improvement through demarcation induces a 23 to 43 percent shift toward long-term investment on treated parcels. We explore gender and parcel location as relevant dimensions of heterogeneity. We find that female-managed landholdings in treated villages are more likely to be left fallow—an important soil fertility investment. Women respond to an exogenous tenure security change by shifting investment away from relatively secure, demarcated land and toward less secure land outside the village to guard those parcels.},
  langid = {english},
  keywords = {Agricultural investment,Gender,Land administration,Natural resources,Property rights},
  file = {H\:\\My Drive\\B\\zotero\\storage\\2KRZ5G36\\Goldstein et al_2018_Formalization without certification.pdf;H\:\\My Drive\\B\\zotero\\storage\\25PIYU6X\\S030438781730127X.html}
}

